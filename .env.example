# Copy this file to .env and fill in your local values.
# The .env file is ignored by git.

# Backend
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_BASE_URL=https://api.openai.com

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/little_moments
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://*.ngrok-free.app

# Frontend (Vite)
# Required for Supabase-first MVP.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
